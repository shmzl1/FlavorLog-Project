# =========================
# App
# =========================
APP_NAME=FlavorLog Backend
APP_ENV=development
DEBUG=True

# =========================
# Server
# =========================
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api/v1

# =========================
# Database
# =========================
DATABASE_URL=postgresql://flavorlog:flavorlog123@localhost:5432/flavorlog_db

DB_HOST=localhost
DB_PORT=5432
DB_NAME=flavorlog_db
DB_USER=flavorlog
DB_PASSWORD=flavorlog123

# =========================
# JWT
# =========================
SECRET_KEY=please_change_this_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =========================
# Upload Directories
# =========================
UPLOAD_IMAGE_DIR=uploads/images
UPLOAD_VIDEO_DIR=uploads/videos
UPLOAD_AUDIO_DIR=uploads/audios

# =========================
# LLM API
# =========================
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.example.com
LLM_MODEL=your_model_name

# =========================
# OCR API
# =========================
OCR_API_KEY=your_ocr_api_key_here
OCR_SECRET_KEY=your_ocr_secret_key_here

# =========================
# Development
# =========================
CORS_ORIGINS=*
LOG_LEVEL=INFO