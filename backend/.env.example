# =========================
# FlavorLog 后端环境变量模板
# 复制为 backend/.env 后使用
# =========================

APP_NAME=FlavorLog Backend
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true

# =========================
# 服务配置
# =========================
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api/v1

# =========================
# 数据库配置
# =========================
DATABASE_URL=postgresql+psycopg2://flavorlog_user:flavorlog_password@localhost:5432/flavorlog
POSTGRES_DB=flavorlog
POSTGRES_USER=flavorlog_user
POSTGRES_PASSWORD=flavorlog_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =========================
# JWT 配置
# =========================
JWT_SECRET_KEY=please_change_this_secret_key_in_local_env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# =========================
# CORS 配置
# 多个来源用英文逗号分隔
# =========================
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:8000,http://localhost:8000

# =========================
# 上传文件配置
# =========================
UPLOAD_DIR=uploads
IMAGE_UPLOAD_DIR=uploads/images
AUDIO_UPLOAD_DIR=uploads/audios
VIDEO_UPLOAD_DIR=uploads/videos
MAX_IMAGE_SIZE_MB=10
MAX_AUDIO_SIZE_MB=30
MAX_VIDEO_SIZE_MB=200

# =========================
# LLM 配置
# 阶段一默认 mock，不调用真实大模型
# =========================
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=60

# =========================
# OCR 配置
# 阶段一默认 mock
# =========================
OCR_PROVIDER=mock
OCR_API_KEY=
OCR_TIMEOUT_SECONDS=30

# =========================
# 日志
# =========================
LOG_LEVEL=INFO