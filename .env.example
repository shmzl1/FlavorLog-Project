# =========================
# FlavorLog 根目录环境变量模板
# 复制为 .env 后使用
# =========================

# 项目基础信息
PROJECT_NAME=FlavorLog
PROJECT_ENV=development
PROJECT_VERSION=0.1.0

# =========================
# PostgreSQL Docker 配置
# =========================
POSTGRES_IMAGE=postgres:16
POSTGRES_CONTAINER_NAME=flavorlog-postgres

POSTGRES_DB=flavorlog
POSTGRES_USER=flavorlog_user
POSTGRES_PASSWORD=flavorlog_password

# 注意：
# POSTGRES_HOST_PORT 是宿主机端口，也就是电脑本机访问数据库用的端口。
# POSTGRES_CONTAINER_PORT 是容器内部 PostgreSQL 端口，通常固定为 5432。
# 如果你电脑本机没有装 PostgreSQL，也可以把 5433 改成 5432。
POSTGRES_HOST=localhost
POSTGRES_HOST_PORT=5433
POSTGRES_CONTAINER_PORT=5432

# 本机后端连接 Docker 中 PostgreSQL 时使用
DATABASE_URL=postgresql+psycopg2://flavorlog_user:flavorlog_password@localhost:5433/flavorlog

# =========================
# 后端服务配置
# =========================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_PREFIX=/api/v1

# 本机浏览器访问
LOCAL_BACKEND_BASE_URL=http://127.0.0.1:8000
LOCAL_API_BASE_URL=http://127.0.0.1:8000/api/v1

# 手机真机联调时，将 192.168.1.100 替换为后端电脑的局域网 IP
LAN_BACKEND_BASE_URL=http://192.168.1.100:8000
LAN_API_BASE_URL=http://192.168.1.100:8000/api/v1

# =========================
# 前端配置
# =========================
FLUTTER_ENV=development

# =========================
# 安全配置
# =========================
JWT_SECRET_KEY=please_change_this_secret_key_in_local_env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# =========================
# 文件上传配置
# =========================
UPLOAD_DIR=backend/uploads
MAX_IMAGE_SIZE_MB=10
MAX_AUDIO_SIZE_MB=30
MAX_VIDEO_SIZE_MB=200

# =========================
# 第三方 AI / LLM 配置
# 阶段一可以先不填，用 Mock 返回
# =========================
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=

OCR_PROVIDER=mock
OCR_API_KEY=

# =========================
# CORS 配置
# 多个来源用英文逗号分隔
# =========================
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:8000,http://localhost:8000

# =========================
# 日志配置
# =========================
LOG_LEVEL=INFO